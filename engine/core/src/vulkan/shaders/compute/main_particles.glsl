struct Particle
{
  vec3 position;
  vec4 colour;
  vec3 velocity;
};

layout(push_constant) uniform PushConstants
{
  int tick;
} constants;

//layout(std140, set = 0, binding = 0) readonly buffer ParticlesUbo
//{
//} emitter;

layout(std140, set = 0, binding = 0) readonly buffer ParticlesInSsbo
{
  Particle particlesIn[];
};

layout(std140, set = 0, binding = 1) writeonly buffer ParticlesOutSsbo
{
  Particle particlesOut[];
};

layout (local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

float random(uint number, float min, float max)
{
  uint mod1024 = number % 1024;
  float s = RANDOM[mod1024];
  return s * (max - min) + min;
}

void main()
{
  const uint index = gl_GlobalInvocationID.x;
  Particle particleIn = particlesIn[index];

  // TODO: Move to UBO
  const float emitterMinX = -1.5;
  const float emitterMinZ = -1.5;
  const float emitterMaxX = 1.5;
  const float emitterMaxZ = 1.5;
  const float lateralSpeed = 0.02;

  float xRange = emitterMaxX - emitterMinX;
  float zRange = emitterMaxZ - emitterMinZ;
  float xMid = emitterMinX + xRange * 0.5;
  float zMid = emitterMinZ + zRange * 0.5;

  particlesOut[index].position = particleIn.position + particleIn.velocity;
  float dx = abs(particleIn.position.x - xMid);
  float dz = abs(particleIn.position.z - zMid);
  particleIn.colour.a *= 1.0 / (1.0 + particleIn.velocity.y * 0.4 + (dx + dz) * 0.02);
  particlesOut[index].colour = particleIn.colour;
  particlesOut[index].velocity.y = particleIn.velocity.y + 0.004;

  if (particleIn.colour.a < 0.02) {
    uint t = constants.tick * 10000;

    particlesOut[index].velocity = vec3(
      random(t + index + 0, -lateralSpeed, lateralSpeed),
      random(t + index + 1, 0.0, 0.02),
      random(t + index + 2, -lateralSpeed, lateralSpeed)
    );
    float x = random(t + index + 3, emitterMinX, emitterMaxX);
    float z = random(t + index + 4, emitterMinZ, emitterMaxZ);
    particlesOut[index].position = vec3(x, 0.0, z);
    particlesOut[index].colour.a = 0.8;
  }
}
