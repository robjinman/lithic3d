  <resources>
    <textures>
      <texture name="grass" file="grass.png"/>
      <texture name="dirt" file="dirt.png"/>
      <texture name="sand" file="sand.png"/>
      <texture name="pebbles" file="pebbles.png"/>
      <texture name="terrain_height_map" file="terrain_height_map.png"/>
      <texture name="terrain_texture_map" file="terrain_texture_map.png"/>
    </textures>
    <materials>
      <!-- Optionally customise materials loaded by models
      <material name="glass" has-transparency="true"/>-->
    </materials>
    <models>
      <model name="cube" casts-shadow="true" instanced="false"/>
      <model name="monkey" casts-shadow="true" instanced="false"/>
      <model name="bendy" casts-shadow="true" instanced="false"/>
