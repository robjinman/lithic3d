<shaders>
  <!-- Text, sprites, and quads -->
  <shader>
    <render_passes>
      <render_pass>overlay</render_pass>
    </render_passes>
    <mesh_features>
      <vertex_layout>
        <position>true</position>
        <normal>*</normal>
        <uv>true</uv>
        <tangent>false</tangent>
        <joint_indices>false</joint_indices>
        <joint_weights>false</joint_weights>
      </vertex_layout>
      <flags>
        <is_instanced>false</is_instanced>
        <is_skybox>false</is_skybox>
        <is_animated>false</is_animated>
        <!--<has_tangents>false</has_tangents>-->
        <casts_shadow>false</casts_shadow>
        <is_quad>*</is_quad>
        <is_dynamic_text>*</is_dynamic_text>
      </flags>
    </mesh_features>
    <material_features>
      <flags>
        <has_transparency>false</has_transparency>
        <has_texture>*</has_texture>
        <has_normal_map>false</has_normal_map>
        <has_cube_map>false</has_cube_map>
        <is_double_sided>false</is_double_sided>
      </flags>
    </material_features>
  </shader>

  <!-- Non-animated 3D models -->
  <shader>
    <render_passes>
      <render_pass>main</render_pass>
    </render_passes>
    <mesh_features>
      <vertex_layout>
        <position>true</position>
        <normal>true</normal>
        <uv>true</uv>
        <tangent>false</tangent>
        <joint_indices>false</joint_indices>
        <joint_weights>false</joint_weights>
      </vertex_layout>
      <flags>
        <is_instanced>false</is_instanced>
        <is_skybox>false</is_skybox>
        <is_animated>false</is_animated>
        <!--<has_tangents>*</has_tangents>-->
        <casts_shadow>false</casts_shadow>
        <is_quad>false</is_quad>
        <is_dynamic_text>false</is_dynamic_text>
      </flags>
    </mesh_features>
    <material_features>
      <flags>
        <has_transparency>false</has_transparency>
        <has_texture>true</has_texture>
        <has_normal_map>false</has_normal_map>
        <has_cube_map>false</has_cube_map>
        <is_double_sided>false</is_double_sided>
      </flags>
    </material_features>
  </shader>
</shaders>
