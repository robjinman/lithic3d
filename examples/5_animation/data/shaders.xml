<shaders>
  <!-- Text, sprites, and quads -->
  <shader>
    <render-passes>
      <render-pass>overlay</render-pass>
    </render-passes>
    <mesh-features>
      <vertex-layout>
        <position>true</position>
        <normal>*</normal>
        <uv>true</uv>
        <tangent>false</tangent>
        <joint-indices>false</joint-indices>
        <joint-weights>false</joint-weights>
      </vertex-layout>
      <flags>
        <is-instanced>false</is-instanced>
        <is-skybox>false</is-skybox>
        <is-animated>false</is-animated>
        <!--<has-tangents>false</has-tangents>-->
        <casts-shadow>false</casts-shadow>
        <is-quad>*</is-quad>
        <is-dynamic-text>*</is-dynamic-text>
      </flags>
    </mesh-features>
    <material-features>
      <flags>
        <has-transparency>false</has-transparency>
        <has-texture>*</has-texture>
        <has-normal-map>false</has-normal-map>
        <has-cube-map>false</has-cube-map>
        <is-double-sided>false</is-double-sided>
      </flags>
    </material-features>
  </shader>

  <!-- Animated 3D models -->
  <shader>
    <render-passes>
      <render-pass>main</render-pass>
    </render-passes>
    <mesh-features>
      <vertex-layout>
        <position>true</position>
        <normal>true</normal>
        <uv>true</uv>
        <tangent>false</tangent>
        <joint-indices>true</joint-indices>
        <joint-weights>true</joint-weights>
      </vertex-layout>
      <flags>
        <is-instanced>false</is-instanced>
        <is-skybox>false</is-skybox>
        <is-animated>true</is-animated>
        <!--<has-tangents>*</has-tangents>-->
        <casts-shadow>true</casts-shadow>
        <is-quad>false</is-quad>
        <is-dynamic-text>false</is-dynamic-text>
      </flags>
    </mesh-features>
    <material-features>
      <flags>
        <has-transparency>false</has-transparency>
        <has-texture>true</has-texture>
        <has-normal-map>false</has-normal-map>
        <has-cube-map>false</has-cube-map>
        <is-double-sided>false</is-double-sided>
      </flags>
    </material-features>
  </shader>

  <shader>
    <render-passes>
      <render-pass>shadow</render-pass>
    </render-passes>
    <mesh-features>
      <vertex-layout>
        <position>true</position>
        <normal>true</normal>
        <uv>true</uv>
        <tangent>false</tangent>
        <joint-indices>true</joint-indices>
        <joint-weights>true</joint-weights>
      </vertex-layout>
      <flags>
        <is-instanced>false</is-instanced>
        <is-skybox>false</is-skybox>
        <is-animated>true</is-animated>
        <!--<has-tangents>*</has-tangents>-->
        <casts-shadow>true</casts-shadow>
        <is-quad>false</is-quad>
        <is-dynamic-text>false</is-dynamic-text>
      </flags>
    </mesh-features>
    <material-features>
      <flags>
        <has-transparency>false</has-transparency>
        <has-texture>false</has-texture>
        <has-normal-map>false</has-normal-map>
        <has-cube-map>false</has-cube-map>
        <is-double-sided>false</is-double-sided>
      </flags>
    </material-features>
  </shader>

  <!-- Animated 3D models (normal mapped) -->
  <shader>
    <render-passes>
      <render-pass>main</render-pass>
    </render-passes>
    <mesh-features>
      <vertex-layout>
        <position>true</position>
        <normal>true</normal>
        <uv>true</uv>
        <tangent>true</tangent>
        <joint-indices>true</joint-indices>
        <joint-weights>true</joint-weights>
      </vertex-layout>
      <flags>
        <is-instanced>false</is-instanced>
        <is-skybox>false</is-skybox>
        <is-animated>true</is-animated>
        <!--<has-tangents>*</has-tangents>-->
        <casts-shadow>true</casts-shadow>
        <is-quad>false</is-quad>
        <is-dynamic-text>false</is-dynamic-text>
      </flags>
    </mesh-features>
    <material-features>
      <flags>
        <has-transparency>false</has-transparency>
        <has-texture>true</has-texture>
        <has-normal-map>true</has-normal-map>
        <has-cube-map>false</has-cube-map>
        <is-double-sided>false</is-double-sided>
      </flags>
    </material-features>
  </shader>

  <shader>
    <render-passes>
      <render-pass>shadow</render-pass>
    </render-passes>
    <mesh-features>
      <vertex-layout>
        <position>true</position>
        <normal>true</normal>
        <uv>true</uv>
        <tangent>true</tangent>
        <joint-indices>true</joint-indices>
        <joint-weights>true</joint-weights>
      </vertex-layout>
      <flags>
        <is-instanced>false</is-instanced>
        <is-skybox>false</is-skybox>
        <is-animated>true</is-animated>
        <!--<has-tangents>*</has-tangents>-->
        <casts-shadow>true</casts-shadow>
        <is-quad>false</is-quad>
        <is-dynamic-text>false</is-dynamic-text>
      </flags>
    </mesh-features>
    <material-features>
      <flags>
        <has-transparency>false</has-transparency>
        <has-texture>false</has-texture>
        <has-normal-map>false</has-normal-map>
        <has-cube-map>false</has-cube-map>
        <is-double-sided>false</is-double-sided>
      </flags>
    </material-features>
  </shader>
</shaders>
