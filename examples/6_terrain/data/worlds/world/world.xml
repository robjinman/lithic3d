<world grid-width="4" grid-height="4" cell-slice-width="10.0" cell-slice-height="10.0">
  <terrain height-map="terrain_height_map">
    <textures>
      <texture name="grass" file="grass.png"/>
      <texture name="dirt" file="dirt.png"/>
      <texture name="sand" file="sand.png"/>
      <texture name="pebbles" file="pebbles.png"/>
      <texture name="terrain_height_map" file="terrain_height_map.png"/>
      <texture name="terrain_texture_map" file="terrain_texture_map.png"/>
    </textures>
    <texture-map texture="terrain_texture_map" r="grass" g="dirt" b="sand" a="pebbles"/>
  </terrain>
</world>
